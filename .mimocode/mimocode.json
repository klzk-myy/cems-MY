{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "mcp": {
    "laravel-boost": {
      "type": "local",
      "enabled": true,
      "command": [
        "php",
        "artisan",
        "boost:mcp"
      ]
    },
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@playwright/mcp"
      ]
    },
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "@upstash/context7-mcp"
      ]
    },
    "gitnexus": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/luzenkock/.npm-global/bin/gitnexus",
        "mcp"
      ]
    }
  }
}
