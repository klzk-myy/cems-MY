{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "playwright": {
            "command": "npx",
            "args": [
                "playwright-mcp"
            ]
        },
        "context7": {
            "command": "npx",
            "args": [
                "context7-mcp"
            ]
        }
    }
}